{
  "name": "hickey",
  "description": "A memory system that leaves a mark. Transparent auto-capture with hybrid FTS5 + vector search.",
  "version": "0.1.0",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "hickey start 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "curl -s -X POST http://localhost:8420/hook -H 'Content-Type: application/json' -d \"$(cat)\"",
            "timeout": 120000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -X POST http://localhost:8420/hook -H 'Content-Type: application/json' -d \"$(cat)\"",
            "timeout": 120000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -X POST http://localhost:8420/hook -H 'Content-Type: application/json' -d \"$(cat)\"",
            "timeout": 120000
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "hickey": {
      "type": "http",
      "url": "http://localhost:8420/mcp"
    }
  }
}
